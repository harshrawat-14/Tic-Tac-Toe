# Render backend environment variables
# Use this only for reference. In Render dashboard, set these in your web service.

# From your Render PostgreSQL instance (Connections/Info page)
DB_HOST=your-postgres-host
DB_PORT=5432
DB_USER=your-postgres-user
DB_PASSWORD=your-postgres-password
DB_NAME=nakama

# Generate strong random values (Render has a Generate button)
NAKAMA_SERVER_KEY=replace-with-random-secret
NAKAMA_SESSION_ENCRYPTION_KEY=replace-with-random-secret
NAKAMA_SESSION_REFRESH_ENCRYPTION_KEY=replace-with-random-secret
NAKAMA_RUNTIME_HTTP_KEY=replace-with-random-secret
