{
  "name": "tictactoe-nakama-backend",
  "version": "1.0.0",
  "scripts": {
    "build": "npx esbuild src/main.ts --bundle --platform=node --target=es2015 --outfile=build/index.js",
    "watch": "npx esbuild src/main.ts --bundle --platform=node --target=es2015 --outfile=build/index.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "nakama-runtime": "github:heroiclabs/nakama-common",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0"
  }
}
