{
  "name": "tictactoe-nakama-backend",
  "version": "1.0.0",
  "scripts": {
    "build": "node build.js",
    "watch": "npx esbuild src/main.ts --bundle --format=iife --global-name=__nakamaExports --outfile=build/index.js --watch",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "nakama-runtime": "github:heroiclabs/nakama-common",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0"
  }
}
