# ── Tic-Tac-Toe Nakama — Environment Variables ────────────────────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  Never commit .env to git.
#     Only .env.example (with safe defaults) should be committed.

# ── Nakama Server ─────────────────────────────────────────────────────────────

# The "server key" clients must send when opening a connection.
# Change this in any non-local environment.
NAKAMA_SERVER_KEY=defaultkey

# Nakama host for backend-to-backend or tooling connections.
NAKAMA_HOST=localhost

# HTTP API port (used by the Nakama JS client SDK).
NAKAMA_PORT=7350

# Set to true if your Nakama instance is behind TLS (e.g. production).
NAKAMA_SSL=false

# ── Nakama Console (developer dashboard) ─────────────────────────────────────
NAKAMA_CONSOLE_USERNAME=admin
NAKAMA_CONSOLE_PASSWORD=password

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# These are injected into the React bundle via import.meta.env.VITE_*
# They must start with VITE_ to be exposed to the browser.

VITE_NAKAMA_HOST=localhost
VITE_NAKAMA_PORT=7350
VITE_NAKAMA_USE_SSL=false

# The server key the Nakama JS client SDK sends during device auth.
VITE_NAKAMA_SERVER_KEY=defaultkey

# ── CockroachDB (docker-compose only) ────────────────────────────────────────
# Used by the cockroachdb container; change the port if 26257 is taken.
COCKROACH_PORT=26257
COCKROACH_HTTP_PORT=8080
